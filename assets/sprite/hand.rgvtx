#i traced over the doom hud for this one :3
#it's not very pretty
scale(10,10)
fill((0,0),(10,1.2),rgb(0,0,0),'#')
lines(
  [(0,0),(10,0),(10,1.2),(0,1.2),(0,0)],
  rgb(255,255,255)
)
lines(
  [
    (4.1,1.2),(4.2,1.4),(4.2,1.6),(4.6,1.9),(4.6,1.7),
    (4.8,1.5),(5.2,1.5),(5.4,1.7),(5.6,1.6),(5.7,1.2),
    (4.1,1.2)
  ],
  rgb(255,0,0)
)
polygon(
  [
    (4.6,2),(4.6,1.7),(4.8,1.5),(5.2,1.5),(5.4,1.7),(5.4,2.3),
    (5.3,2.7),(5.1,2.9),(4.9,2.9),(4.7,2.3),(4.6,2)
  ],
  rgb(0,0,255),'@'
)
lines(
  [
    (4.6,2),(4.6,1.7),(4.8,1.5),(5.2,1.5),(5.4,1.7),(5.4,2.3),
    (5.3,2.7),(5.1,2.9),(4.9,2.9),(4.7,2.3),(4.5,2.2),(4.6,2)
  ],
  rgb(0,0,255)
)
char((0,10),':')char((0.1,10),'3')
color((0,10),rgb(255,255,255))color((0.1,10),rgb(255,255,255))